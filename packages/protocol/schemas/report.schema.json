{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harness.local/schemas/report.schema.json",
  "title": "Harness Task Report",
  "description": "任务完成后的结构化报告对象。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "intent",
    "conclusion",
    "actual_scope",
    "evidence_summary",
    "remaining_risks",
    "next_steps",
    "completed_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.3"
    },
    "task_id": {
      "type": "string"
    },
    "intent": {
      "type": "string"
    },
    "conclusion": {
      "type": "string",
      "minLength": 1,
      "description": "任务结论：根因判断（bug）、交付内容（feature）、调研结论（explore）"
    },
    "actual_scope": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "实际改动或分析范围，与合同 scope 对比"
    },
    "scope_deviation": {
      "type": ["string", "null"],
      "description": "与原始 scope 的偏差说明，无偏差时为 null"
    },
    "evidence_summary": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "result"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "command_result",
              "test_result",
              "diff_summary",
              "artifact",
              "reasoning_note",
              "manual_confirmation"
            ]
          },
          "result": {
            "type": "string"
          },
          "passed": {
            "type": "boolean"
          }
        }
      }
    },
    "remaining_risks": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "剩余风险，无则为空数组"
    },
    "overrides_used": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "本次任务中使用的 force_override 摘要"
    },
    "output_artifacts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "changelog": {
          "$ref": "#/$defs/output_artifact"
        },
        "design_note": {
          "$ref": "#/$defs/output_artifact"
        },
        "adr": {
          "$ref": "#/$defs/output_artifact"
        }
      }
    },
    "delivery_readiness": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "signals": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/delivery_signal"
          }
        },
        "commit": {
          "$ref": "#/$defs/delivery_readiness"
        },
        "push": {
          "$ref": "#/$defs/delivery_readiness"
        }
      }
    },
    "next_steps": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "下一步建议"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "output_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "required",
        "satisfied",
        "reason"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "path": {
          "type": [
            "string",
            "null"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "satisfied": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "delivery_readiness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "configured",
        "mode",
        "via",
        "ready",
        "required_signals",
        "satisfied_signals",
        "missing_signals",
        "reason"
      ],
      "properties": {
        "configured": {
          "type": "boolean"
        },
        "mode": {
          "type": [
            "string",
            "null"
          ]
        },
        "via": {
          "type": [
            "string",
            "null"
          ]
        },
        "ready": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "required_signals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "satisfied_signals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missing_signals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "delivery_signal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "satisfied",
        "reason"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "satisfied": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        }
      }
    }
  }
}
