{
  "name": "agent-harness",
  "private": true,
  "version": "0.1.2",
  "description": "Monorepo for the agent-harness runtime and protocol.",
  "license": "MIT",
  "workspaces": [
    "packages/protocol",
    "packages/cli"
  ],
  "scripts": {
    "cli:help": "node packages/cli/bin/agent-harness.js --help",
    "codex:hooks:check": "node --check .harness/hosts/codex/hooks/user_prompt_submit_intake.js && node --check .harness/hosts/codex/hooks/session_start_restore.js && node --check .harness/hosts/codex/hooks/pre_tool_use_gate.js && node --check .harness/hosts/codex/hooks/post_tool_use_record_evidence.js",
    "codex:hooks:status": "node packages/cli/bin/agent-harness.js status",
    "codex:e2e": "node packages/cli/scripts/verify-codex-e2e.js",
    "runtime:host-hooks": "node packages/cli/scripts/verify-host-hooks-smoke.js",
    "runtime:init-status": "node packages/cli/scripts/verify-host-init-status.js",
    "runtime:p0:check": "npm --prefix packages/cli run verify:task-core && npm --prefix packages/cli run verify:host-hooks && npm --prefix packages/cli run verify:init-status",
    "runtime:p1:check": "npm --prefix packages/cli run verify:host-hooks && npm --prefix packages/cli run verify:init-status && npm --prefix packages/cli run verify:status-compat",
    "release:pack:protocol": "npm pack --dry-run --workspace @brawnen/agent-harness-protocol --cache ./.npm-cache",
    "release:pack:cli": "npm pack --dry-run --workspace @brawnen/agent-harness-cli --cache ./.npm-cache",
    "release:publish:protocol": "npm publish --workspace @brawnen/agent-harness-protocol --cache ./.npm-cache",
    "release:publish:cli": "npm publish --workspace @brawnen/agent-harness-cli --cache ./.npm-cache"
  },
  "engines": {
    "node": ">=18"
  }
}
