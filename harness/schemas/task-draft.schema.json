{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harness.local/schemas/task-draft.schema.json",
  "title": "Harness Task Draft",
  "description": "Intake 阶段内部使用的任务草稿对象。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source_input",
    "intent",
    "goal",
    "scope",
    "acceptance",
    "constraints",
    "mode",
    "assumptions",
    "open_questions",
    "risk_signals",
    "context_refs",
    "next_action"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.2"
    },
    "source_input": {
      "type": "string",
      "minLength": 1
    },
    "intent": {
      "type": "string",
      "enum": [
        "bug",
        "feature",
        "explore",
        "refactor",
        "prototype",
        "unknown"
      ]
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "acceptance": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "mode": {
      "type": "string",
      "enum": [
        "delivery",
        "explore",
        "poc",
        "unknown"
      ]
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "risk_signals": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "context_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "next_action": {
      "type": "string",
      "enum": [
        "clarify",
        "plan",
        "observe",
        "fail"
      ]
    },
    "derived": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "risk_level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "unknown"
          ]
        },
        "state": {
          "type": "string",
          "enum": [
            "draft",
            "needs_clarification",
            "planned",
            "failed"
          ]
        }
      }
    }
  }
}
