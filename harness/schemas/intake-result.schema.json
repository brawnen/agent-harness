{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harness.local/schemas/intake-result.schema.json",
  "title": "Harness Intake Result",
  "description": "最小 intake CLI 的标准输出对象。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "command",
    "status",
    "task_draft",
    "interaction"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.3"
    },
    "command": {
      "type": "string",
      "const": "intake"
    },
    "status": {
      "type": "string",
      "enum": [
        "planned",
        "needs_clarification",
        "failed"
      ]
    },
    "task_draft": {
      "$ref": "./task-draft.schema.json"
    },
    "interaction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "assumptions",
        "blocking_gap",
        "question",
        "next_action"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "blocking_gap": {
          "type": [
            "string",
            "null"
          ]
        },
        "question": {
          "type": [
            "string",
            "null"
          ]
        },
        "next_action": {
          "type": "string",
          "enum": [
            "clarify",
            "plan",
            "observe",
            "fail"
          ]
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "project": {
          "type": "string"
        },
        "config_path": {
          "type": "string"
        },
        "generated_at": {
          "type": "string"
        }
      }
    }
  }
}
