{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harness.local/schemas/audit-log.schema.json",
  "title": "Harness Audit Log",
  "description": "门禁违规、force_override、补救动作的审计日志。",
  "$defs": {
    "audit_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_type",
        "task_id",
        "phase",
        "signal",
        "description",
        "timestamp"
      ],
      "properties": {
        "event_type": {
          "type": "string",
          "enum": [
            "force_override",
            "gate_violation",
            "remediation",
            "state_recovery",
            "manual_confirmation"
          ]
        },
        "task_id": {
          "type": "string"
        },
        "phase": {
          "type": "string",
          "enum": [
            "intake",
            "clarify",
            "plan",
            "execute",
            "verify",
            "report",
            "close"
          ]
        },
        "signal": {
          "type": "string",
          "description": "触发此事件的控制信号名，例如 block_plan、block_execution"
        },
        "description": {
          "description": "事件描述：被跳过的门禁、违规内容、补救措施",
          "type": "string"
        },
        "user_input": {
          "type": ["string", "null"],
          "description": "触发 override 的用户原文，非 override 事件可为 null"
        },
        "risk_at_time": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "unknown"
          ]
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "entries"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.3"
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/audit_entry"
      }
    }
  }
}
